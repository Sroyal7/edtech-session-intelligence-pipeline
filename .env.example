# EdTech Session Intelligence Pipeline - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Model selection (default: claude-3-5-sonnet-20241022)
# Use claude-3-5-sonnet-20241022 for cost-efficiency at volume
# Use claude-opus-4-5 for highest accuracy on complex sessions
MODEL=claude-3-5-sonnet-20241022

# Optional: Max tokens in Claude response (default: 1500)
MAX_TOKENS=1500

# Optional: Confidence threshold for quality gate (default: 0.6)
# Profiles below this score get flagged for manual review before CRM push
CONFIDENCE_THRESHOLD=0.6

# Optional: Your platform name for logging (default: EdTech Platform)
PLATFORM_NAME=Your Platform Name

# Optional: CRM API key (used in push_to_crm() once wired up)
# CRM_API_KEY=your-crm-api-key-here
